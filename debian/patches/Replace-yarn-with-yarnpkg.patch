From: Sophie Brun <sophie@kali.org>
Date: Thu, 24 Oct 2024 16:15:59 +0200
Subject: Replace yarn with yarnpkg

In Debian the command yarn is named yarnpkg
---
 cmd/ui/package.json                          |  4 ++--
 package.json                                 | 20 ++++++++++----------
 packages/go/stbernard/workspace/yarn/yarn.go |  8 ++++----
 3 files changed, 16 insertions(+), 16 deletions(-)

diff --git a/cmd/ui/package.json b/cmd/ui/package.json
index e061ece..b36f35e 100644
--- a/cmd/ui/package.json
+++ b/cmd/ui/package.json
@@ -7,10 +7,10 @@
         "debug": "vite --debug",
         "dev": "vite",
         "start": "vite",
-        "build": "yarn check-types && vite build",
+        "build": "yarnpkg check-types && vite build",
         "preview": "vite preview",
         "test": "TZ=America/Los_Angeles vitest",
-        "check-types": "yarn workspaces foreach -ptRv --include '{bh-shared-ui,js-client-library}' run build && tsc --noEmit --pretty",
+        "check-types": "yarnpkg workspaces foreach -ptRv --include '{bh-shared-ui,js-client-library}' run build && tsc --noEmit --pretty",
         "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
         "format": "prettier --write \"src/**/*.@(js|jsx|ts|tsx|md|html|css|scss|json)\"",
         "check-format": "prettier  --list-different \"src/**/*.@(js|jsx|ts|tsx|md|html|css|scss|json)\""
diff --git a/package.json b/package.json
index 4cfcf76..444b744 100644
--- a/package.json
+++ b/package.json
@@ -8,16 +8,16 @@
     ]
   },
   "scripts": {
-    "dev": "yarn workspace bloodhound-ui dev",
-    "debug": "yarn workspace bloodhound-ui debug",
-    "start": "yarn workspace bloodhound-ui start",
-    "preview": "yarn workspace bloodhound-ui preview",
-    "build": "yarn workspaces foreach -ptv run build",
-    "test": "yarn workspaces foreach -ptv run test run",
-    "check-types": "yarn workspaces foreach -ptv run check-types",
-    "lint": "yarn workspaces foreach -ptv run lint",
-    "format": "yarn workspaces foreach -ptv run format",
-    "check-format": "yarn workspaces foreach -ptv run check-format"
+    "dev": "yarnpkg workspace bloodhound-ui dev",
+    "debug": "yarnpkg workspace bloodhound-ui debug",
+    "start": "yarnpkg workspace bloodhound-ui start",
+    "preview": "yarnpkg workspace bloodhound-ui preview",
+    "build": "yarnpkg workspaces foreach -ptv run build",
+    "test": "yarnpkg workspaces foreach -ptv run test run",
+    "check-types": "yarnpkg workspaces foreach -ptv run check-types",
+    "lint": "yarnpkg workspaces foreach -ptv run lint",
+    "format": "yarnpkg workspaces foreach -ptv run format",
+    "check-format": "yarnpkg workspaces foreach -ptv run check-format"
   },
   "packageManager": "yarn@3.5.1",
   "devDependencies": {
diff --git a/packages/go/stbernard/workspace/yarn/yarn.go b/packages/go/stbernard/workspace/yarn/yarn.go
